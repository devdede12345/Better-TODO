{
  "name": "obsidian-better-todo",
  "version": "0.1.0",
  "description": "Better TODO — Obsidian plugin",
  "main": "main.js",
  "scripts": {
    "dev:js": "node esbuild.config.mjs",
    "dev:css": "tailwindcss -i ./src/styles.css -o ./styles.css --watch",
    "dev": "npm run build:css && npm run dev:js",
    "build:css": "tailwindcss -i ./src/styles.css -o ./styles.css --minify",
    "build": "npm run build:css && tsc -noEmit -skipLibCheck && node esbuild.config.mjs production"
  },
  "keywords": ["obsidian", "plugin", "todo", "tasks", "timeline"],
  "author": "devdede",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.21.4",
    "obsidian": "latest",
    "tslib": "^2.6.2",
    "typescript": "^5.4.0",
    "tailwindcss": "^3.4.10",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.45"
  },
  "dependencies": {
    "lucide-react": "^0.446.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
